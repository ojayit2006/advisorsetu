# Azure Avatar + STT (reused from kumbhsaathi-ipad)
SPEECH_KEY=
SPEECH_REGION=eastus2

# Orchestrator LLM — Gemini primary, Groq fallback if Gemini errors (quota/outage)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — leave blank to run in MOCK_MODE (seeded Rahul Verma fixture, no DB needed)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Force mock mode even if Supabase is configured: MOCK_MODE=1
MOCK_MODE=

DEMO_ACTOR=mia-wealth-app
BOOTH_ID=


# Tavus AI Avatar
TAVUS_API_KEY=
TAVUS_REPLICA_ID=r9fa0878977a

# Public base URL for Tavus webhook (use ngrok in dev, deployed URL in prod)
TAVUS_WEBHOOK_BASE_URL=http://localhost:8000
