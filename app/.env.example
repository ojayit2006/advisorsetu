# Backend base URL (FastAPI). Read via expo-constants (app.json "extra.apiBaseUrl")
# with this env var taking priority when set — see src/api.js.
#
# - Simulator / Expo web on the SAME machine as the backend: http://localhost:8000
# - Physical phone in Expo Go: MUST be your computer's LAN IP, not localhost, e.g.
#     EXPO_PUBLIC_API_BASE_URL=http://192.168.1.23:8000
#   (find it with `ipconfig` on Windows — look for IPv4 Address on your Wi-Fi adapter)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
